<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.AndroidAppTemplate" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <!-- Cor principal (fundo dark) -->
        <item name="colorPrimary">#121212</item>
        <item name="colorPrimaryVariant">#000000</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Cor secundária (vermelho do app) -->
        <item name="colorSecondary">#FF3B3B</item>
        <item name="colorSecondaryVariant">#FF0000</item>
        <item name="colorOnSecondary">#FFFFFF</item>

        <!-- Status bar (barra de cima) -->
        <item name="android:statusBarColor">#000000</item>

        <!-- Barra de navegação (baixo do celular) -->
        <item name="android:navigationBarColor">#000000</item>

        <!-- Fundo geral -->
        <item name="android:windowBackground">#121212</item>

    </style>

</resources>