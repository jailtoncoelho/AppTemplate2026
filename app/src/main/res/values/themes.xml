<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.AndroidAppTemplate" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/fixpro_accent_teal</item>
        <item name="colorPrimaryVariant">@color/fixpro_deep_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        
        <!-- Customize ActionBar Color Only -->
        <item name="actionBarStyle">@style/Widget.AndroidAppTemplate.ActionBar</item>
    </style>

    <style name="Widget.AndroidAppTemplate.ActionBar" parent="Widget.MaterialComponents.ActionBar.Solid">
        <item name="background">@color/fixpro_profile_actionbar</item>
    </style>

    <!-- Login/Cadastro theme (no ActionBar, dark bg) -->
    <style name="Theme.FixPro.Login" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/fixpro_accent_teal</item>
        <item name="colorPrimaryVariant">@color/fixpro_deep_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/fixpro_dark_bg</item>
        <item name="android:windowTranslucentStatus">true</item>
    </style>
</resources>