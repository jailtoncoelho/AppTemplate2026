<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111119"
    android:fillViewport="true"
    android:overScrollMode="never"
    tools:context=".ui.usuario.PerfilUsuarioFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="48dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/btnSettings"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="top|end"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="12dp"
                android:src="@drawable/ic_settings" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="36dp">

            <FrameLayout
                android:layout_width="100dp"
                android:layout_height="100dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_profile_circle" />

                <androidx.cardview.widget.CardView
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:layout_gravity="center"
                    app:cardCornerRadius="44dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@android:color/transparent">

                    <ImageView
                        android:id="@+id/userProfileImageView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:contentDescription="Foto de perfil"
                        android:src="@mipmap/ic_default_user" />
                </androidx.cardview.widget.CardView>
            </FrameLayout>

            <!-- Nome grande -->
            <TextView
                android:id="@+id/textDisplayName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="sans-serif"
                android:letterSpacing="0.01"
                android:text="Usuário"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Email -->
            <TextView
                android:id="@+id/textDisplayEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="email@exemplo.com"
                android:textColor="#80FFFFFF"
                android:textSize="13sp" />
            </LinearLayout>
        </FrameLayout>

        <!-- Espaço entre header e conteúdo -->
        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

        <!-- SEÇÃO: Informações Pessoais -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="34dp"
            android:layout_marginBottom="8dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.08"
            android:text="INFORMAÇÕES PESSOAIS"
            android:textColor="#60FFFFFF"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:background="@drawable/bg_profile_section"
            android:elevation="2dp"
            android:orientation="vertical"
            android:paddingVertical="2dp">

            <!-- Nome -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:alpha="0.6"
                    android:contentDescription="Nome"
                    android:src="@drawable/ic_person" />

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Nome"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/registerNameEditText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:gravity="start"
                    android:hint="Nome completo"
                    android:inputType="textPersonName"
                    android:maxLines="1"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#35FFFFFF"
                    android:textCursorDrawable="@null"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="46dp"
                android:layout_marginEnd="16dp"
                android:background="#0CFFFFFF" />

            <!-- Email -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:alpha="0.6"
                    android:contentDescription="Email"
                    android:src="@drawable/ic_email" />

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Email"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/registerEmailEditText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:gravity="start"
                    android:hint="Seu email"
                    android:inputType="textEmailAddress"
                    android:maxLines="1"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#35FFFFFF"
                    android:textCursorDrawable="@null"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="46dp"
                android:layout_marginEnd="16dp"
                android:background="#0CFFFFFF" />

            <!-- Endereço -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:alpha="0.6"
                    android:contentDescription="Endereço"
                    android:src="@drawable/ic_person" />

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Endereço"
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/registerEnderecoEditText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:gravity="start"
                    android:hint="Endereço"
                    android:inputType="textPostalAddress"
                    android:maxLines="1"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#35FFFFFF"
                    android:textCursorDrawable="@null"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- SEÇÃO: Segurança (oculta quando logado) -->
        <LinearLayout
            android:id="@+id/sectionSenha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="34dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:text="SEGURANÇA"
                android:textColor="#60FFFFFF"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:background="@drawable/bg_profile_section"
                android:elevation="2dp"
                android:orientation="vertical"
                android:paddingVertical="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:alpha="0.6"
                        android:contentDescription="Senha"
                        android:src="@drawable/ic_lock" />

                    <EditText
                        android:id="@+id/registerPasswordEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:background="@android:color/transparent"
                        android:gravity="start"
                        android:hint="Sua senha"
                        android:inputType="textPassword"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#35FFFFFF"
                        android:textCursorDrawable="@null"
                        android:textSize="14sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="46dp"
                    android:layout_marginEnd="16dp"
                    android:background="#0CFFFFFF" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:alpha="0.6"
                        android:contentDescription="Confirmar Senha"
                        android:src="@drawable/ic_lock" />

                    <EditText
                        android:id="@+id/registerConfirmPasswordEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:background="@android:color/transparent"
                        android:gravity="start"
                        android:hint="Confirmar senha"
                        android:inputType="textPassword"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#35FFFFFF"
                        android:textCursorDrawable="@null"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- BOTÃO: Salvar -->
        <Button
            android:id="@+id/salvarButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/ripple_button_primary"
            android:elevation="4dp"
            android:letterSpacing="0.05"
            android:stateListAnimator="@null"
            android:text="Salvar alterações"
            android:textAllCaps="false"
            android:textColor="@color/fixpro_deep_blue"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Versão -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:text="FixPro v1.0"
            android:textColor="#20FFFFFF"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
