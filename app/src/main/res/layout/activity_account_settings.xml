<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111119"
    android:orientation="vertical">



    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="16dp"
        android:fontFamily="sans-serif-medium"
        android:text="Acesso e segurança"
        android:textColor="#60FFFFFF"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/bg_profile_section_neutral"
        android:elevation="2dp"
        android:orientation="vertical">

        <!-- Sair da conta -->
        <LinearLayout
            android:id="@+id/sairButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/ripple_row"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sair da conta"
                android:textColor="#DDFFFFFF"
                android:textSize="15sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#0CFFFFFF" />

        <!-- Apagar Conta -->
        <LinearLayout
            android:id="@+id/apagarContaButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/ripple_row"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Apagar minha conta"
                android:textColor="#FF453A"
                android:textSize="15sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
